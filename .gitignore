# =============================================================================
# GIS data
# -----------------------------------------------------------------------------
# Bell snapshot GeoJSON is large; keep it local (download with
# scripts/download_arcgis_geojson.py). The public site uses live ArcGIS; admin
# preview is ?adminGeojson=1 with a local http server. Only small contract
# files (e.g. schema.json) belong in the repo.
# =============================================================================

# Local snapshot files (per-year folders under data/geojson/<county>/)
data/geojson/**/*.geojson
# Regenerated with the snapshots; omit from the repo
data/geojson/**/manifest.json
data/geojson/**/README.md

# Atomic-write temp files produced by scripts/download_arcgis_geojson.py
*.geojson.tmp

# Non-canonical local GIS exports (shapefile / geopackage sidecars)
*.gpkg
*.shp
*.shx
*.dbf
*.prj
*.cpg
*.sbn
*.sbx
*.qix
